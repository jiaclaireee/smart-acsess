APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
UP_EMAIL_DOMAINS=up.edu.ph,uplb.edu.ph

CHATBOT_CONTEXT_TTL=30
CHATBOT_HISTORY_TTL=240
CHATBOT_HISTORY_LIMIT=20
CHATBOT_KNOWLEDGE_DISK=local
CHATBOT_KNOWLEDGE_PATH=private/chatbot-knowledge
CHATBOT_KNOWLEDGE_VERSION=1
CHATBOT_KNOWLEDGE_REFRESH_ON_ASK=true
CHATBOT_RESOURCE_CONTEXT_LIMIT=20
CHATBOT_SAMPLE_ROWS_LIMIT=5
CHATBOT_TOP_GROUP_LIMIT=6
CHATBOT_TREND_LIMIT=12
CHATBOT_PROJECTION_LOOKBACK_DAYS=90
CHATBOT_PROJECTION_DAILY_LIMIT=120
CHATBOT_PROJECTION_EXPECTED_MULTIPLIER=1.05
CHATBOT_PROJECTION_HIGH_MULTIPLIER=1.12
CHATBOT_PROJECTION_MAJOR_EVENT_EXPECTED_MULTIPLIER=1.20
CHATBOT_PROJECTION_MAJOR_EVENT_HIGH_MULTIPLIER=1.35
CHATBOT_EXTERNAL_KNOWLEDGE_ENABLED=true
CHATBOT_LLM_ENABLED=false
CHATBOT_LLM_PROVIDER=openai_compatible
CHATBOT_LLM_BASE_URL=https://api.openai.com/v1
CHATBOT_LLM_API_KEY=
CHATBOT_LLM_MODEL=gpt-4o-mini
CHATBOT_LLM_TIMEOUT=20
